# Lê a mensagem do commit
commit_msg=$(cat "$1")

# Cores para o terminal
RED="\033[0;31m"
GREEN="\033[0;32m"
YELLOW="\033[1;33m"
BOLD="\033[1m"
RESET="\033[0m"

# Define os prefixos válidos
valid_prefixes="^(feat|fix|docs|test|build|perf|style|refactor|chore|ci|raw|cleanup|remove):"

# Verifica se a mensagem começa com um dos prefixos válidos
if ! echo "$commit_msg" | grep -qE "$valid_prefixes"; then
  echo ""
  echo -e "❌ ${RED}${BOLD}Invalid commit message.${RESET}"
  echo ""

  echo -e "${YELLOW}A mensagem deve começar com um dos seguintes prefixos:${RESET}"
  echo ""
  echo "  feat:     Indicam que seu trecho de código está incluindo um novo recurso (se relaciona com o MINOR do versionamento semântico)."
  echo "  fix:      Indicam que seu trecho de código commitado está solucionando um problema (bug fix), (se relaciona com o PATCH do versionamento semântico)."
  echo "  docs:     Indicam que houveram mudanças na documentação, como por exemplo no Readme do seu repositório. (Não inclui alterações em código)."
  echo "  test:     São utilizados quando são realizadas alterações em testes, seja criando, alterando ou excluindo testes unitários. (Não inclui alterações em código)."
  echo "  build:    São utilizados quando são realizadas modificações em arquivos de build e dependências."
  echo "  perf:     Servem para identificar quaisquer alterações de código que estejam relacionadas a performance."
  echo "  style:    Indicam que houveram alterações referentes a formatações de código, semicolons, trailing spaces, lint... (Não inclui alterações em código)."
  echo "  refactor: Referem-se a mudanças devido a refatorações que não alterem sua funcionalidade, como por exemplo, uma alteração no formato como é processada determinada parte da tela, mas que manteve a mesma funcionalidade, ou melhorias de performance devido a um code review."
  echo "  chore:    Indicam atualizações de tarefas de build, configurações de administrador, pacotes... como por exemplo adicionar um pacote no gitignore. (Não inclui alterações em código)"
  echo "  ci:       Indicam mudanças relacionadas a integração contínua (continuous integration)."
  echo "  raw:      Mudanças relacionadas a arquivos de configurações, dados, features, parâmetros."
  echo "  cleanup:  São utilizados para remover código comentado, trechos desnecessários ou qualquer outra forma de limpeza do código-fonte, visando aprimorar sua legibilidade e manutenibilidade."
  echo "  remove:   Indicam a exclusão de arquivos, diretórios ou funcionalidades obsoletas ou não utilizadas, reduzindo o tamanho e a complexidade do projeto e mantendo-o mais organizado."
  echo ""
  echo -e "${YELLOW}Valid examples:${RESET}"
  echo "  git commit -m \"feat: add new feature\""
  echo "  git commit -m \"fix: resolve bug in login\""
  echo ""

  # Mostra a primeira linha do commit para ajudar o dev a ver o erro
  first_line=$(printf '%s\n' "$commit_msg" | head -n 1)
  echo -e "${YELLOW}Current message:${RESET} \"$first_line\""
  echo ""
  exit 1
fi

# Mensagem de sucesso mais descritiva
echo -e "✅ ${GREEN}Commit message válida de acordo com o padrão definido.${RESET}"